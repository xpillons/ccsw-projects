---
cluster: "<%= global_ccw_clusters %>"
<%-

gpu_count=num_gpus.to_i
scheduler_args = ["-N", "1"]
scheduler_args += ["-p", global_ccw_queues]
if gpu_count > 0
  scheduler_args += ["--gpus=%d" % gpu_count]
end
scheduler_args += ["--exclusive"]
-%>

batch_connect:
  template: basic
  conn_file: "connection.yml"
  conn_params:
    - host
    - port
    - user
    - job_id
    - password
    - client_path

# NOTE: For the native client support to work you need:
# 1. Direct SSH access between users and the compute nodes/ThinLinc servers
# 2. Set the custom virtual host directives in the installation.md
# 3. Change the enabled_client variable in view.html.erb

script:
  job_name: "thinlinc"
  native:
  <%- scheduler_args.each do |arg| %>
    - "<%= arg %>"
  <%- end %>
